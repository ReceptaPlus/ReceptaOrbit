# Copie para .env e ajuste. Nunca commitar .env real.
NODE_ENV=development

# Banco — Railway PostgreSQL
# LOCAL (rodar migration da sua máquina): use a URL PÚBLICA da Railway
#   Railway → serviço Postgres → aba "Variables" → copie DATABASE_PUBLIC_URL
#   (host tipo *.proxy.rlwy.net:PORTA). Acrescente ?sslmode=require.
DATABASE_URL="postgresql://postgres:SENHA@HOST.proxy.rlwy.net:PORTA/railway?sslmode=require"
DIRECT_DATABASE_URL="postgresql://postgres:SENHA@HOST.proxy.rlwy.net:PORTA/railway?sslmode=require"
# DEPLOY (app rodando NA Railway): troque pela URL INTERNA (postgres.railway.internal)
#   via reference variable ${{Postgres.DATABASE_URL}} — mais rápida, sem sair da rede.
#
# Fallback offline (Docker local): docker compose up -d e use
#   postgresql://orbit:orbit@localhost:5432/recepta_orbit?schema=public

# Segredo de hash de senha (pepper) — fora do banco, diferente por ambiente.
# Gere forte em prod: openssl rand -base64 32.
PASSWORD_PEPPER="dev-only-change-me"
# Pepper ANTERIOR (opcional) — aceito só na verificação, p/ rotacionar sem invalidar hashes.
# PASSWORD_PEPPER_OLD="pepper-antigo"

# Senha das contas criadas pelo seed (npm run db:seed). NUNCA usar senha fraca/fixa
# em banco compartilhado. Se vazia, o seed gera uma forte e imprime uma vez.
SEED_PASSWORD=

# Fases futuras (§25 da arquitetura) — ainda não usados:
# AUTH_SECRET=
# ENCRYPTION_KEY=
# EVOLUTION_BASE_URL=
# EVOLUTION_GLOBAL_API_KEY=
# AI_PROVIDER=
# AI_API_KEY=
# AI_MODEL=
