# Copie para .env e ajuste. Nunca commitar .env real.
NODE_ENV=development

# Banco (Docker Compose local — ver docker-compose.yml)
DATABASE_URL="postgresql://orbit:orbit@localhost:5432/recepta_orbit?schema=public"
DIRECT_DATABASE_URL="postgresql://orbit:orbit@localhost:5432/recepta_orbit?schema=public"

# Segredo de hash de senha (pepper) — fora do banco, diferente por ambiente
PASSWORD_PEPPER="dev-only-change-me"

