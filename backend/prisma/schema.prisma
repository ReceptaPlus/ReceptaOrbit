// Recepta Orbit — Schema Prisma
// FASE 1 (fundação): identidade, multi-tenancy, RBAC, primeiro acesso, termos/privacidade, auditoria.
// V1 INGESTÃO ("espionagem" WhatsApp): WhatsAppConnection, Contact, ConversationCycle, Message, WebhookEvent.
// IA (análise externa via n8n; app só exibe): CycleAnalysis (venda por ciclo) + SalesReport (relatório do dono).
// Fora de escopo (fase futura): Sale, SaleItem, TrackingLink.
// Autoridade: docs/DOMAIN-MODEL.md + docs/CONTRATOS-FRONTEND.md (congelados) +
// frontend/src/types/domain.ts. Convenção: model PascalCase, coluna/tabela snake_case via @map/@@map.
// Multi-tenant: pharmacy_id NOT NULL no domínio; FK compostas (id, pharmacy_id) impedem mistura de tenants.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum PharmacyStatus {
  ACTIVE
  SUSPENDED
}

enum PlanType {
  START
  PRO
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TenantRole {
  OWNER
  MANAGER
  VIEWER
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum PlatformRole {
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
}

enum LegalDocumentType {
  TERMS_OF_USE
  PRIVACY_POLICY
}

enum ActorType {
  USER
  AI
  SYSTEM
}

// Lista congelada (CONTRATOS-FRONTEND Parte 1). Nem toda ação é usada na Fase 1,
// mas o enum nasce completo para evitar migrações repetidas de enum nas próximas fases.
enum AuditAction {
  SALE_CONFIRMED
  SALE_REJECTED
  SALE_REFUNDED
  SALE_VALUE_CORRECTED
  CLASSIFICATION_CORRECTED
  USER_INVITED
  INVITE_CANCELLED
  INVITE_RESENT
  MEMBERSHIP_SUSPENDED
  MEMBERSHIP_REACTIVATED
  WHATSAPP_CONNECTED
  WHATSAPP_DISCONNECTED
  AI_THRESHOLD_CHANGED
  PHARMACY_UPDATED
  PHARMACY_CREATED
}

// ── V1 Ingestão (espionagem WhatsApp) ────────────────────────────────────────

enum WhatsAppState {
  DISCONNECTED
  PAIRING
  CONNECTED
  DOWN
}

enum CycleStatus {
  OPEN
  WAITING_CUSTOMER
  WAITING_PHARMACY
  CLOSED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum WebhookEventStatus {
  PENDING
  PROCESSING // reivindicado por um worker (claim atômico FOR UPDATE SKIP LOCKED)
  PROCESSED
  FAILED // dead-letter: erro permanente ou esgotou as tentativas
}

// Provider de canal por farmácia. EVOLUTION = WhatsApp via QR (instância própria).
// DIGISAC = plataforma de atendimento multicanal (WhatsApp/Instagram/Telegram/...).
// Aditivo: a farmácia usa Evolution OU um provider multicanal (escolha por-tenant).
enum ChannelProvider {
  EVOLUTION
  DIGISAC
}

// ── Tenancy ────────────────────────────────────────────────────────────────

model Pharmacy {
  id                     String         @id @default(uuid()) @db.Uuid
  tradeName              String         @map("trade_name")
  legalName              String         @map("legal_name")
  cnpj                   String         @unique
  slug                   String         @unique
  timezone               String         @default("America/Sao_Paulo")
  plan                   PlanType       @default(START)
  status                 PharmacyStatus @default(ACTIVE)
  aiAutoConfirmThreshold Float          @default(0.85) @map("ai_auto_confirm_threshold")
  aiSummaryLanguage      String         @default("pt-BR") @map("ai_summary_language")
  agenteClientId         String?        @map("agente_client_id") // FK lógica -> Client.id no banco do Agente-Meta-Ads (cross-DB, sem constraint)
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  memberships        Membership[]
  auditLogs          AuditLog[]
  whatsAppConnection WhatsAppConnection?
  channelConnections ChannelConnection[]
  contacts           Contact[]
  salesReports       SalesReport[]

  @@map("pharmacies")
}

// ── Identity & Access ────────────────────────────────────────────────────────

// User é identidade GLOBAL (não pertence a tenant). Vínculo com farmácia = Membership.
model User {
  id                 String     @id @default(uuid()) @db.Uuid
  name               String
  email              String     @unique
  passwordHash       String?    @map("password_hash") // null até o 1º acesso (define senha)
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(true) @map("must_change_password")
  sessionVersion     Int        @default(0) @map("session_version") // incrementa → invalida sessões
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  platformStaff      PlatformStaff?
  memberships        Membership[]          @relation("MembershipUser")
  invitedMemberships Membership[]          @relation("MembershipInvitedBy")
  invitations        UserInvitation[]      @relation("InvitationUser")
  createdInvitations UserInvitation[]      @relation("InvitationCreatedBy")
  legalAcceptances   UserLegalAcceptance[]
  conversationReads  ConversationRead[]

  @@map("users")
}

// Papéis de plataforma — separados do tenant (anti-pattern 4 do DOMAIN-MODEL).
model PlatformStaff {
  userId    String       @id @map("user_id") @db.Uuid
  role      PlatformRole
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_staff")
}

// Vínculo User×Pharmacy×papel — é ELE que é convidado/suspenso.
model Membership {
  id              String           @id @default(uuid()) @db.Uuid
  pharmacyId      String           @map("pharmacy_id") @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  role            TenantRole
  status          MembershipStatus @default(INVITED)
  invitedByUserId String?          @map("invited_by_user_id") @db.Uuid
  inviteExpiresAt DateTime?        @map("invite_expires_at") @db.Timestamptz
  lastAccessAt    DateTime?        @map("last_access_at") @db.Timestamptz
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  pharmacy  Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  user      User     @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?    @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([pharmacyId, userId])
  @@index([userId])
  @@index([pharmacyId])
  @@map("pharmacy_memberships")
}

// Convite de 1º acesso — armazena apenas HASH do token; uso único; expira.
model UserInvitation {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  tokenHash       String    @unique @map("token_hash")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  usedAt          DateTime? @map("used_at") @db.Timestamptz
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user      User @relation("InvitationUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User @relation("InvitationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_invitations")
}

// ── Legal (LGPD) ─────────────────────────────────────────────────────────────

model LegalDocument {
  id          String            @id @default(uuid()) @db.Uuid
  type        LegalDocumentType
  version     String
  contentUrl  String            @map("content_url")
  contentHash String            @map("content_hash")
  active      Boolean           @default(true)
  publishedAt DateTime          @map("published_at") @db.Timestamptz
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz

  acceptances UserLegalAcceptance[]

  @@unique([type, version])
  @@map("legal_documents")
}

// Aceite versionado — não basta um booleano (registra documento, versão, IP, UA).
model UserLegalAcceptance {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  legalDocumentId String   @map("legal_document_id") @db.Uuid
  acceptedAt      DateTime @default(now()) @map("accepted_at") @db.Timestamptz
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalDocument LegalDocument @relation(fields: [legalDocumentId], references: [id])

  @@unique([userId, legalDocumentId])
  @@index([userId])
  @@map("user_legal_acceptances")
}

// ── Audit (append-only) ──────────────────────────────────────────────────────

// Trilha imutável. Ator USER/AI/SYSTEM; staff sempre com onBehalfOf (pharmacyId).
// Sem rota de update/delete na aplicação.
model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  pharmacyId  String      @map("pharmacy_id") @db.Uuid
  actorType   ActorType   @map("actor_type")
  actorUserId String?     @map("actor_user_id") @db.Uuid
  actorModel  String?     @map("actor_model") // quando actorType = AI
  onBehalfOf  String?     @map("on_behalf_of") @db.Uuid // staff agindo no tenant
  action      AuditAction
  entityType  String      @map("entity_type")
  entityId    String      @map("entity_id")
  before      Json?
  after       Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, entityType, createdAt])
  @@index([pharmacyId, createdAt])
  @@map("audit_logs")
}

// ── V1 Ingestão — WhatsApp / Conversas (espionagem) ──────────────────────────

// Estado do pareamento Evolution — máquina de 4 estados (1:1 com Pharmacy).
// Alimenta o GlobalBanner (DOWN) e a tela de pareamento.
model WhatsAppConnection {
  pharmacyId     String        @id @map("pharmacy_id") @db.Uuid
  state          WhatsAppState @default(DISCONNECTED)
  pairedNumber   String?       @map("paired_number")
  instanceName   String?       @unique @map("instance_name") // instância Evolution → resolve tenant no webhook
  stateChangedAt DateTime      @default(now()) @map("state_changed_at") @db.Timestamptz
  qrExpiresAt    DateTime?     @map("qr_expires_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@map("whatsapp_connections")
}

// Pessoa-cliente consolidada por telefone DENTRO do tenant. "Cliente" é estado
// derivado (compra > 0) — fora da V1. Projeções (contagens/totais) são calculadas
// por query, nunca colunas-verdade (DOMAIN-MODEL regra 9 / anti-pattern 2).
model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  pharmacyId  String   @map("pharmacy_id") @db.Uuid
  name        String // fallback = telefone
  phoneE164   String   @map("phone_e164")
  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.Timestamptz
  lastSeenAt  DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pharmacy Pharmacy            @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  cycles   ConversationCycle[]

  @@unique([pharmacyId, phoneE164]) // telefone único POR tenant (regra 11)
  @@unique([id, pharmacyId]) // alvo da FK composta dos ciclos (regra 12)
  @@index([pharmacyId, lastSeenAt])
  @@map("contacts")
}

// Janela de 24h de conversa — unidade de agrupamento. Sem IA na V1: status é
// mecânico (tempo + direção da última msg); attribution fica nulo até a IA entrar.
// Classificação NUNCA é campo do ciclo (anti-pattern 1).
model ConversationCycle {
  id            String      @id @default(uuid()) @db.Uuid
  pharmacyId    String      @map("pharmacy_id") @db.Uuid
  contactId     String      @map("contact_id") @db.Uuid
  startedAt     DateTime    @default(now()) @map("started_at") @db.Timestamptz
  expiresAt     DateTime    @map("expires_at") @db.Timestamptz // startedAt + 24h
  lastMessageAt DateTime    @map("last_message_at") @db.Timestamptz
  status        CycleStatus @default(OPEN)
  attribution   Json? // VO-snapshot; populado quando atribuição/IA entrar
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  contact  Contact   @relation(fields: [contactId, pharmacyId], references: [id, pharmacyId], onDelete: Cascade)
  messages Message[]
  reads    ConversationRead[]
  analysis CycleAnalysis? // resultado da IA (1:1; populado pelo n8n via endpoint interno)
  // NOTA migration (SQL manual — Prisma não suporta índice filtrado):
  //  · UNIQUE parcial (pharmacy_id, contact_id) WHERE status='OPEN' → invariante "1 ciclo OPEN"
  //  · índice parcial (pharmacy_id, contact_id) WHERE status='OPEN' → caminho quente do worker

  @@unique([id, pharmacyId]) // alvo da FK composta das mensagens (regra 12)
  @@index([pharmacyId, contactId])
  @@index([pharmacyId, lastMessageAt])
  @@map("conversation_cycles")
}

// Marca quais ciclos cada usuário JÁ ABRIU — alimenta o badge "não vistas" no menu.
// Ausência de linha = nunca aberto (conta no badge); presença = visto (sai do badge).
model ConversationRead {
  userId  String   @map("user_id") @db.Uuid
  cycleId String   @map("cycle_id") @db.Uuid
  seenAt  DateTime @default(now()) @map("seen_at") @db.Timestamptz

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle ConversationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@id([userId, cycleId])
  @@index([cycleId])
  @@map("conversation_reads")
}

// Mensagem individual — espelho IMUTÁVEL do WhatsApp; fonte de verdade da auditoria.
// Ninguém altera/exclui. providerMessageId vem da Evolution (dedup de rajada/replay).
model Message {
  id                String           @id @default(uuid()) @db.Uuid
  pharmacyId        String           @map("pharmacy_id") @db.Uuid
  cycleId           String           @map("cycle_id") @db.Uuid
  direction         MessageDirection
  textContent       String           @map("text_content")
  providerMessageId String?          @map("provider_message_id")
  sentAt            DateTime         @map("sent_at") @db.Timestamptz
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz

  cycle ConversationCycle @relation(fields: [cycleId, pharmacyId], references: [id, pharmacyId], onDelete: Cascade)

  @@unique([pharmacyId, providerMessageId]) // dedup (nulos são distintos no Postgres)
  @@index([pharmacyId, cycleId, sentAt])
  @@map("messages")
}

// Payload bruto do webhook Evolution — replay/debug. SEPARADO da Message (risco de
// schema 1 / escalabilidade). pharmacy_id nulo até resolver instância→tenant.
// Sem FK p/ Pharmacy: tabela de pouso aceita eventos não-casados.
model WebhookEvent {
  id           String             @id @default(uuid()) @db.Uuid
  pharmacyId   String?            @map("pharmacy_id") @db.Uuid
  provider     ChannelProvider    @default(EVOLUTION)
  instanceName String?            @map("instance_name") // Evolution: nome da instância
  externalId   String?            @map("external_id") // Digisac: serviceId do canal → resolve tenant
  eventType    String?            @map("event_type")
  payload      Json
  status       WebhookEventStatus @default(PENDING)
  attempts     Int                @default(0) // nº de tentativas já feitas (retry com backoff)
  nextRetryAt  DateTime?          @map("next_retry_at") @db.Timestamptz // PENDING só é reivindicado quando <= now; em PROCESSING vira o deadline de visibilidade (reaper de crash)
  error        String?
  receivedAt   DateTime           @default(now()) @map("received_at") @db.Timestamptz
  processedAt  DateTime?          @map("processed_at") @db.Timestamptz

  @@index([status, receivedAt])
  @@map("webhook_events")
}

// Conexão a um provider de canal multicanal (hoje: Digisac). Coexiste com
// WhatsAppConnection (Evolution) sem migrar o que já funciona. Uma farmácia pode
// ter várias (ex.: vários "services" Digisac). Ingestão V1 só precisa de:
//   · externalId  → resolve o tenant a partir do webhook (serviceId)
//   · webhookSecretHash → autentica o webhook (segredo nunca em claro: só SHA-256)
// apiBaseUrl/token (outbound) ficam para quando houver envio pelo app.
model ChannelConnection {
  id                String          @id @default(uuid()) @db.Uuid
  pharmacyId        String          @map("pharmacy_id") @db.Uuid
  provider          ChannelProvider
  externalId        String          @map("external_id") // serviceId/accountId no payload do webhook
  label             String? // nome amigável do canal (ex.: "WhatsApp Loja Centro")
  apiBaseUrl        String?         @map("api_base_url") // ex.: https://{conta}.digisac.me/api/v1 (outbound futuro)
  webhookSecretHash String          @map("webhook_secret_hash") // SHA-256 do segredo do webhook
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId]) // (DIGISAC, serviceId) → uma conexão → um tenant
  @@index([pharmacyId])
  @@map("channel_connections")
}

// ── IA — Análise de conversas (produzida FORA do app, pelo n8n) ───────────────

// Resultado da IA por ciclo (1:1). O app NÃO roda LLM: o n8n lê o ciclo via endpoint
// interno, classifica e devolve aqui. Idempotente: analyzedThroughMessageAt registra
// até qual ponto a conversa já foi analisada — só reprocessa se chegou msg nova.
model CycleAnalysis {
  id                       String   @id @default(uuid()) @db.Uuid
  pharmacyId               String   @map("pharmacy_id") @db.Uuid
  cycleId                  String   @map("cycle_id") @db.Uuid
  isSale                   Boolean  @map("is_sale") // a conversa virou venda?
  saleValueCents           Int?     @map("sale_value_cents") // valor estimado da venda (centavos)
  stage                    String? // estágio do funil (texto livre da IA)
  lossReason               String?  @map("loss_reason") // motivo de perda quando isSale=false
  summary                  String // resumo curto da conversa (pt-BR)
  confidence               Float // 0..1 — confiança da classificação
  model                    String // modelo usado (ex.: claude-...)
  analyzedAt               DateTime @default(now()) @map("analyzed_at") @db.Timestamptz
  analyzedThroughMessageAt DateTime @map("analyzed_through_message_at") @db.Timestamptz // gate de re-análise
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cycle ConversationCycle @relation(fields: [cycleId, pharmacyId], references: [id, pharmacyId], onDelete: Cascade)

  @@unique([cycleId, pharmacyId]) // 1:1 com o ciclo + idempotência do upsert
  @@index([pharmacyId, isSale])
  @@index([pharmacyId, analyzedAt])
  @@map("cycle_analyses")
}

// Relatório agregado por farmácia/período — narrativa curta pro dono (vendas × volume
// de conversas). Snapshot das métricas no momento da geração (não recalcula histórico).
// Também produzido pelo n8n via endpoint interno.
model SalesReport {
  id                String   @id @default(uuid()) @db.Uuid
  pharmacyId        String   @map("pharmacy_id") @db.Uuid
  periodStart       DateTime @map("period_start") @db.Timestamptz
  periodEnd         DateTime @map("period_end") @db.Timestamptz
  narrative         String // resumo curto pro dono (pt-BR)
  salesCount        Int      @map("sales_count")
  salesValueCents   Int      @map("sales_value_cents")
  conversationCount Int      @map("conversation_count")
  conversionRate    Float    @map("conversion_rate") // salesCount / conversationCount
  model             String
  generatedAt       DateTime @default(now()) @map("generated_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, periodEnd])
  @@map("sales_reports")
}
